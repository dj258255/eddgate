{
  "name": "eddgate",
  "version": "0.1.0",
  "description": "EDDOps-native multi-agent CLI — evaluation-driven agent workflows",
  "type": "module",
  "bin": {
    "eddgate": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "eddops.config.yaml",
    "README.md",
    "ARCHITECTURE.md"
  ],
  "keywords": [
    "eddgate",
    "multi-agent",
    "workflow",
    "evaluation",
    "llm",
    "claude",
    "cli",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dj258255/eddgate.git"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/runner": "^4.1.2",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
