{
  "name": "eddgate",
  "version": "0.1.0",
  "description": "Evaluation-gated workflow engine for LLM agents",
  "type": "module",
  "bin": {
    "eddgate": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "eddgate.config.yaml",
    "README.md"
  ],
  "keywords": [
    "eddgate",
    "evaluation",
    "workflow",
    "validation",
    "llm",
    "agent",
    "cli",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dj258255/eddgate.git"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@types/node": "^22.0.0",
    "@vitest/runner": "^4.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
